#include "esp_camera.h"
#include <WiFi.h>
#include <WebServer.h>
#include "quirc.h"

const char* ssid = "ESPCAM";
const char* password = "12345678";

WebServer server(80);
WiFiServer streamServer(81);

// CAMERA PINS
#define PWDN_GPIO_NUM     -1
#define RESET_GPIO_NUM    -1
#define XCLK_GPIO_NUM     15
#define SIOD_GPIO_NUM     4
#define SIOC_GPIO_NUM     5
#define Y9_GPIO_NUM       16
#define Y8_GPIO_NUM       17
#define Y7_GPIO_NUM       18
#define Y6_GPIO_NUM       12
#define Y5_GPIO_NUM       10
#define Y4_GPIO_NUM       8
#define Y3_GPIO_NUM       9
#define Y2_GPIO_NUM       11
#define VSYNC_GPIO_NUM    6
#define HREF_GPIO_NUM     7
#define PCLK_GPIO_NUM     13

struct quirc *qr = NULL;
String latest_qr = "";
volatile bool new_qr_ready = false;

// ----------------------------------------------------
// HTML Dashboard
// ----------------------------------------------------
const char* index_html = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Max-FPS QR & Stream</title>
  <style>
    body { background: #121212; color: #eee; display: flex; flex-direction: column; align-items: center; font-family: sans-serif; margin: 0; padding: 20px; }
    h2 { color: #4CAF50; }
    p { color: #888; margin-bottom: 20px; text-align: center;}
    canvas { 
      background: #000;
      border: 1px solid #333; 
      border-radius: 8px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5); 
      image-rendering: auto; 
      width: 640px; 
      transform: scaleX(-1); /* Mirror camera */
    }
    #fps { font-weight: bold; color: #ff9800; }
    #qr_result { margin-top: 15px; padding: 10px; background: #222; border-radius: 5px; width: 620px; text-align: center; font-family: monospace; font-size: 22px; color: #00FF00; min-height: 30px; word-wrap: break-word; transition: 0.3s;}
  </style>
</head>
<body>
  <h2>QR Scanner & Live Feed (Dual-Port)</h2>
  <p>QR scanning and UI on Port 80. Raw Video on Port 81.<br>Zero Threads Blocked | Stream FPS: <span id="fps">0</span></p>
  <canvas id="canvas"></canvas>
  <div id="qr_result">Waiting for QR Code...</div>
  
  <script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    const fpsElem = document.getElementById('fps');
    
    let imgData = null;
    let frames = 0;
    setInterval(() => { fpsElem.innerText = frames; frames = 0; }, 1000);

    // Fetch QR on the control port (80) smoothly
    setInterval(async () => {
      try {
        let r = await fetch('/qr');
        if (!r.ok) return;
        let txt = await r.text();
        if (txt && txt.trim() !== "") {
            const el = document.getElementById('qr_result');
            el.innerText = txt;
            el.style.color = '#fff';
            el.style.backgroundColor = '#e91e63';
            setTimeout(()=>{el.style.color='#00FF00'; el.style.backgroundColor='#222';}, 800);
        }
      } catch(e) {}
    }, 500);

    // Fetch Video on the dedicated stream port (81)
    async function stream() {
      while(true) {
        try {
          const streamUrl = 'http://' + window.location.hostname + ':81/';
          const res = await fetch(streamUrl);
          if (!res.ok) {
            await new Promise(r => setTimeout(r, 1000));
            continue;
          }
          const reader = res.body.getReader();
          let buffer = new Uint8Array(0);
          
          while (true) {
            const { value, done } = await reader.read();
            if (done) break;
            
            let newBuffer = new Uint8Array(buffer.length + value.length);
            newBuffer.set(buffer, 0);
            newBuffer.set(value, buffer.length);
            buffer = newBuffer;
            
            while (buffer.length >= 12) {
              if (buffer[0] !== 0xAA || buffer[1] !== 0xBB || buffer[2] !== 0xCC || buffer[3] !== 0xDD) {
                let found = false;
                for(let i=1; i < buffer.length - 3; i++) {
                  if (buffer[i] === 0xAA && buffer[i+1] === 0xBB && buffer[i+2] === 0xCC && buffer[i+3] === 0xDD) {
                    buffer = buffer.slice(i);
                    found = true;
                    break;
                  }
                }
                if(!found){ buffer = new Uint8Array(0); break; }
              }
              if(buffer.length < 12) break;
              
              const view = new DataView(buffer.buffer, buffer.byteOffset, buffer.byteLength);
              const width = view.getUint16(4, true);
              const height = view.getUint16(6, true);
              const len = view.getUint32(8, true);
              
              if (buffer.length >= 12 + len) {
                const frameData = buffer.slice(12, 12 + len);
                buffer = buffer.slice(12 + len); 
                
                if(canvas.width !== width || canvas.height !== height) {
                  canvas.width = width;
                  canvas.height = height;
                  imgData = ctx.createImageData(width, height);
                }
                
                for (let i = 0; i < len; i++) {
                  let p = i * 4;
                  imgData.data[p] = frameData[i];     // R
                  imgData.data[p + 1] = frameData[i]; // G
                  imgData.data[p + 2] = frameData[i]; // B
                  imgData.data[p + 3] = 255;          // Alpha
                }
                ctx.putImageData(imgData, 0, 0);
                frames++;
              } else {
                break; 
              }
            }
          }
        } catch (err) {
          console.error("Stream disconnect/error:", err);
        }
        await new Promise(r => setTimeout(r, 1000));
      }
    }
    stream();
  </script>
