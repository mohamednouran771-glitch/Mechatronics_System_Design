void handleRoot() {
  server.send(200, "text/html", index_html);
}

void handleQR() {
  if (new_qr_ready) {
    server.send(200, "text/plain", latest_qr);
    new_qr_ready = false; 
  } else {
    server.send(200, "text/plain", "");
  }
}

// ----------------------------------------------------
// QR Code Reader Task (Running on FreeRTOS Core 0)
// ----------------------------------------------------
void qrTask(void *pvParameters) {
  qr = quirc_new();
  if (qr) {
      Serial.println("QR Code Decoder initialized on Core 0.");
  } else {
      Serial.println("WARNING: Failed to allocate memory for QR decoder.");
      vTaskDelete(NULL);
  }

  while (true) {
    camera_fb_t *fb = esp_camera_fb_get();
    if (!fb) {
      vTaskDelay(100 / portTICK_PERIOD_MS);
      continue;
    }

    if (quirc_resize(qr, fb->width, fb->height) == 0) {
      uint8_t *image = quirc_begin(qr, NULL, NULL);
      if (image) {
        memcpy(image, fb->buf, fb->len);
        quirc_end(qr);
        
        int num_codes = quirc_count(qr);
        if (num_codes > 0) {
          static struct quirc_code code;
          static struct quirc_data data;
          quirc_extract(qr, 0, &code);
          
          if (!quirc_decode(&code, &data)) {
            String payload = String((char*)data.payload);
            
            Serial.println("\n#################################");
            Serial.print("QR FOUND: ");
            Serial.println(payload);
            Serial.println("#################################\n");
            
            latest_qr = payload;
            new_qr_ready = true;
          }
        }
      }
    }

    esp_camera_fb_return(fb);
    vTaskDelay(300 / portTICK_PERIOD_MS); // Run scanner approx 3 times a second
  }
}

// ----------------------------------------------------
// Core Setup & Loop
// ----------------------------------------------------
void setup() {
  Serial.begin(115200);
  delay(1000); 
  Serial.println("\n--- ESP32 Camera Booting (Dual-Port Mode) ---");

  bool has_psram = psramFound();
  if (has_psram) {
    Serial.printf(">>> PSRAM DETECTED: %d bytes\n", ESP.getPsramSize());
  } else {
    Serial.println(">>> NO PSRAM DETECTED");
  }

  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer   = LEDC_TIMER_0;
  config.pin_d0       = Y2_GPIO_NUM;
  config.pin_d1       = Y3_GPIO_NUM;
  config.pin_d2       = Y4_GPIO_NUM;
  config.pin_d3       = Y5_GPIO_NUM;
  config.pin_d4       = Y6_GPIO_NUM;
  config.pin_d5       = Y7_GPIO_NUM;
  config.pin_d6       = Y8_GPIO_NUM;
  config.pin_d7       = Y9_GPIO_NUM;
  config.pin_xclk     = XCLK_GPIO_NUM;
  config.pin_pclk     = PCLK_GPIO_NUM;
  config.pin_vsync    = VSYNC_GPIO_NUM;
  config.pin_href     = HREF_GPIO_NUM;
  config.pin_sccb_sda = SIOD_GPIO_NUM;
  config.pin_sccb_scl = SIOC_GPIO_NUM;
  config.pin_pwdn     = PWDN_GPIO_NUM;
  config.pin_reset    = RESET_GPIO_NUM;
  config.xclk_freq_hz = 20000000;
  
  config.pixel_format = PIXFORMAT_GRAYSCALE;   
  config.frame_size   = FRAMESIZE_QVGA;  // 320x240 ideal for robust QR tracking 
  config.jpeg_quality = 12; 
  
  if (has_psram) {
    config.fb_count     = 2;            
    config.fb_location  = CAMERA_FB_IN_PSRAM;
    config.grab_mode    = CAMERA_GRAB_LATEST;
  } else {
    config.fb_count     = 1;
    config.fb_location  = CAMERA_FB_IN_DRAM;
    config.grab_mode    = CAMERA_GRAB_WHEN_EMPTY;
  }

  if (esp_camera_init(&config) != ESP_OK) {
    Serial.println("Camera init totally failed!");
    while (true);
  }

  // Restore Default sensor settings to prevent crushing details
  sensor_t * s = esp_camera_sensor_get();
  s->set_contrast(s, 0);       
  s->set_brightness(s, 0);    
  s->set_saturation(s, 0);    
  
  // Launch QR task completely independently on Core 0
  xTaskCreatePinnedToCore(qrTask, "QR Task", 15000, NULL, 1, NULL, 0);

  // Start Access Point mode
  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);
  Serial.println("\nAccess Point Started!");
  
  IPAddress IP = WiFi.softAPIP();
  Serial.print("AP IP Address: ");
  Serial.println(IP);
  Serial.println("\n===============================================");
  Serial.print("1. Connect your mobile device to Wi-Fi: ");
  Serial.println(ssid);
  Serial.print("   Password: ");
  Serial.println(password);
  Serial.print("2. Open browser and go to watch stream: http://");
  Serial.println(IP);
  Serial.println("===============================================\n");

  // Port 80 handles UI and Control Endpoints rapidly
  server.on("/", HTTP_GET, handleRoot);
  server.on("/qr", HTTP_GET, handleQR);
  server.onNotFound([]() { server.send(404, "text/plain", "Not Found"); });
  server.begin();

  // Port 81 directly handles raw streaming payload
  streamServer.begin();
  Serial.println("Web Server on Port 80, Stream Server on Port 81");
}

WiFiClient activeStreamClient;
const uint8_t magic_video[4] = {0xAA, 0xBB, 0xCC, 0xDD};

void loop() {
  server.handleClient(); // Handles port 80 effortlessly

  // Check Port 81 for stream connections
  if (streamServer.hasClient()) {
    if (activeStreamClient) activeStreamClient.stop();
    activeStreamClient = streamServer.available();
    
    // Send HTTP headers manually on this raw socket
    activeStreamClient.println("HTTP/1.1 200 OK");
    activeStreamClient.println("Content-Type: application/octet-stream");
    activeStreamClient.println("Connection: close");
    activeStreamClient.println("Access-Control-Allow-Origin: *");
    activeStreamClient.println();
  }

  // Rapidly write raw frames to stream socket without blocking loop
  if (activeStreamClient && activeStreamClient.connected()) {
    camera_fb_t *fb = esp_camera_fb_get();
    if (fb) {
      uint16_t w = fb->width;
      uint16_t h = fb->height;
      uint32_t len = fb->len;

      activeStreamClient.write(magic_video, 4);
      activeStreamClient.write((uint8_t*)&w, 2);
      activeStreamClient.write((uint8_t*)&h, 2);
      activeStreamClient.write((uint8_t*)&len, 4);
      activeStreamClient.write(fb->buf, len);
      esp_camera_fb_return(fb);
    }
  }

  delay(1);
}
